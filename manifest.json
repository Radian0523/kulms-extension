{
  "manifest_version": 3,
  "name": "KULMS+",
  "version": "1.3.0",
  "description": "京都大学LMS (KULMS) を強化するChrome拡張。全科目の課題一覧・締切管理、教科書情報取得、テーマ切替、サイドバーカスタマイズなど15機能を搭載。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.k.kyoto-u.ac.jp/*"],
  "content_scripts": [
    {
      "matches": ["https://lms.gakusei.kyoto-u.ac.jp/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
