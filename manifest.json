{
  "manifest_version": 3,
  "name": "KULMS Extension",
  "version": "1.0.0",
  "description": "京都大学LMS (KULMS) カスタマイズ拡張機能",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://www.k.kyoto-u.ac.jp/*"],
  "content_scripts": [
    {
      "matches": ["https://lms.gakusei.kyoto-u.ac.jp/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
